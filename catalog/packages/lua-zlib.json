{
  "schema_version": 1,
  "package_name": "lua-zlib",
  "rock_name": "lua-zlib",
  "version": null,
  "category": "compression",
  "help_file": "catalog/help/packages/lua-zlib.json",
  "summary": {
    "en": "zlib bindings for compression and decompression streams.",
    "zh": "面向压缩与解压缩流的 zlib 绑定。"
  },
  "modules": [
    {
      "name": "zlib",
      "kind": "native",
      "visibility": "public"
    }
  ],
  "legacy_config": {
    "install": [],
    "args": [],
    "env": [
      {
        "os": "windows",
        "name": "CMAKE_PREFIX_PATH",
        "value_ref": "dep:zlib"
      }
    ],
    "dependencies": [
      {
        "name": "zlib",
        "os": "windows",
        "method": "bundled",
        "url_or_hint": "https://zlib.net/zlib131.zip"
      },
      {
        "name": "zlib",
        "os": "linux",
        "method": "bundled",
        "url_or_hint": "https://github.com/madler/zlib/releases/download/v1.3.1/zlib-1.3.1.tar.gz"
      },
      {
        "name": "zlib",
        "os": "macos",
        "method": "bundled",
        "url_or_hint": "https://github.com/madler/zlib/releases/download/v1.3.1/zlib-1.3.1.tar.gz"
      }
    ],
    "depvars": [
      {
        "dep_name": "zlib",
        "os": "linux",
        "var_name": "ZLIB_DIR",
        "value_ref": "dep:zlib"
      },
      {
        "dep_name": "zlib",
        "os": "linux",
        "var_name": "ZLIB_LIBDIR",
        "value_ref": "dep:zlib/lib"
      },
      {
        "dep_name": "zlib",
        "os": "linux",
        "var_name": "ZLIB_INCDIR",
        "value_ref": "dep:zlib/include"
      },
      {
        "dep_name": "zlib",
        "os": "macos",
        "var_name": "ZLIB_DIR",
        "value_ref": "dep:zlib"
      },
      {
        "dep_name": "zlib",
        "os": "macos",
        "var_name": "ZLIB_LIBDIR",
        "value_ref": "dep:zlib/lib"
      },
      {
        "dep_name": "zlib",
        "os": "macos",
        "var_name": "ZLIB_INCDIR",
        "value_ref": "dep:zlib/include"
      },
      {
        "dep_name": "zlib",
        "os": "windows",
        "var_name": "ZLIB_LIBDIR",
        "value_ref": "dep:zlib/lib"
      },
      {
        "dep_name": "zlib",
        "os": "windows",
        "var_name": "ZLIB_INCDIR",
        "value_ref": "dep:zlib/include"
      }
    ]
  },
  "override_rules": {},
  "artifact_kind": "native",
  "license": {
    "spdx_expression": "MIT",
    "license_name": "MIT License",
    "license_policy": "link-or-fetch",
    "license_url": "https://github.com/brimworks/lua-zlib/blob/master/LICENCE",
    "license_text_url": "https://raw.githubusercontent.com/brimworks/lua-zlib/master/LICENCE"
  },
  "homepage": "https://github.com/brimworks/lua-zlib",
  "repository": "https://github.com/brimworks/lua-zlib",
  "platform_matrix": {
    "windows-x64": {
      "support_status": "supported",
      "build_mode": "upstream-luarocks"
    },
    "linux-x64": {
      "support_status": "supported",
      "build_mode": "upstream-luarocks"
    },
    "linux-arm64": {
      "support_status": "supported",
      "build_mode": "upstream-luarocks"
    },
    "macos-x64": {
      "support_status": "supported",
      "build_mode": "upstream-luarocks"
    },
    "macos-arm64": {
      "support_status": "supported",
      "build_mode": "upstream-luarocks"
    }
  }
}
