{
  "schema_version": 1,
  "package_name": "lua-curl",
  "rock_name": "lua-curl",
  "version": "0.3.13-1",
  "category": "network",
  "homepage": "https://github.com/Lua-cURL",
  "repository": "https://github.com/Lua-cURL/Lua-cURLv3",
  "help_file": "catalog/help/packages/lua-curl.json",
  "summary": {
    "en": "Lua bindings for libcurl, with both high-level and low-level modules.",
    "zh": "面向 libcurl 的 Lua 绑定，包含高层与低层模块。"
  },
  "modules": [
    {
      "name": "cURL",
      "kind": "lua",
      "visibility": "public"
    },
    {
      "name": "cURL.safe",
      "kind": "lua",
      "visibility": "public"
    },
    {
      "name": "cURL.utils",
      "kind": "lua",
      "visibility": "public"
    },
    {
      "name": "cURL.impl.cURL",
      "kind": "lua",
      "visibility": "internal"
    },
    {
      "name": "lcurl",
      "kind": "native",
      "visibility": "public"
    }
  ],
  "legacy_config": {
    "install": [
      {
        "os": "windows",
        "target_ref": "path:dist/luarocks_overrides/windows/lua-curl-0.3.13-1.rockspec"
      }
    ],
    "args": [],
    "env": [],
    "dependencies": [
      {
        "name": "curl",
        "os": "windows",
        "method": "vcpkg",
        "url_or_hint": "https://curl.se/download/curl-8.13.0.tar.gz"
      },
      {
        "name": "curl",
        "os": "linux",
        "method": "bundled",
        "url_or_hint": "https://curl.se/download/curl-8.13.0.tar.gz"
      },
      {
        "name": "curl",
        "os": "macos",
        "method": "bundled",
        "url_or_hint": "https://curl.se/download/curl-8.13.0.tar.gz"
      }
    ],
    "depvars": [
      {
        "dep_name": "curl",
        "os": "linux",
        "var_name": "CURL_DIR",
        "value_ref": "dep:curl"
      },
      {
        "dep_name": "curl",
        "os": "linux",
        "var_name": "CURL_LIBDIR",
        "value_ref": "dep:curl/lib"
      },
      {
        "dep_name": "curl",
        "os": "linux",
        "var_name": "CURL_INCDIR",
        "value_ref": "dep:curl/include"
      },
      {
        "dep_name": "curl",
        "os": "macos",
        "var_name": "CURL_DIR",
        "value_ref": "dep:curl"
      },
      {
        "dep_name": "curl",
        "os": "macos",
        "var_name": "CURL_LIBDIR",
        "value_ref": "dep:curl/lib"
      },
      {
        "dep_name": "curl",
        "os": "macos",
        "var_name": "CURL_INCDIR",
        "value_ref": "dep:curl/include"
      },
      {
        "dep_name": "curl",
        "os": "windows",
        "var_name": "CURL_LIBDIR",
        "value_ref": "dep:curl/lib"
      },
      {
        "dep_name": "curl",
        "os": "windows",
        "var_name": "CURL_INCDIR",
        "value_ref": "dep:curl/include"
      }
    ]
  },
  "override_rules": {
    "windows": "catalog/overrides/windows/lua-curl.json"
  },
  "artifact_kind": "hybrid",
  "license": {
    "spdx_expression": "MIT",
    "license_name": "MIT License",
    "license_policy": "link-or-fetch",
    "license_url": "https://github.com/Lua-cURL/Lua-cURLv3/blob/master/LICENSE",
    "license_text_url": "https://raw.githubusercontent.com/Lua-cURL/Lua-cURLv3/master/LICENSE"
  },
  "platform_matrix": {
    "windows-x64": {
      "support_status": "supported",
      "build_mode": "generated-override"
    },
    "linux-x64": {
      "support_status": "supported",
      "build_mode": "upstream-luarocks"
    },
    "linux-arm64": {
      "support_status": "supported",
      "build_mode": "upstream-luarocks"
    },
    "macos-x64": {
      "support_status": "supported",
      "build_mode": "upstream-luarocks"
    },
    "macos-arm64": {
      "support_status": "supported",
      "build_mode": "upstream-luarocks"
    }
  }
}
